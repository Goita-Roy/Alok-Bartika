PORT=5000
CLIENT_ORIGIN=http://localhost:5173
CLIENT_ORIGINS=http://localhost:5173
MONGO_URI=mongodb://127.0.0.1:27017/alokbartika
ALLOW_START_WITHOUT_DB=true

# JWT (use STRONG unique secrets in production; never commit real values)
JWT_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_COST=12

# Google OAuth (client ID used to verify Google ID tokens)
GOOGLE_CLIENT_ID=

# Cookies
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Brute force protection
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCK_MS=900000

# Rate limits (requests per minute window)
RATE_LIMIT_GENERAL=120
RATE_LIMIT_LOGIN=10
RATE_LIMIT_REGISTER=5
RATE_LIMIT_PASSWORD_RESET=5
RATE_LIMIT_EXAM=30
RATE_LIMIT_PRACTICE=60
RATE_LIMIT_NOTIFICATIONS=60
RATE_LIMIT_PROFILE=30
RATE_LIMIT_WINDOW_MS=60000

# CSRF double-submit protection
CSRF_ENABLED=true

# Uploads
MAX_UPLOAD_BYTES=5242880

# Trust proxy (set true behind a reverse proxy to read real client IP)
TRUST_PROXY=false

JUDGE0_BASE_URL=https://ce.judge0.com
JUDGE0_AUTH_TOKEN=
JUDGE0_TIMEOUT_MS=15000
JUDGE0_MAX_SOURCE_CHARS=20000
